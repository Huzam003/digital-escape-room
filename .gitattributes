# Set default behavior to automatically normalize line endings:
* text=auto

# Declare files that will always have LF line endings on checkout:
*.cpp text eol=lf
*.h text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Denote all files that are truly binary and should not be modified:
*.sln binary
*.vcxproj binary
*.filters binary
*.user binary
